# Telos-Scale Environment Variables

# --- LLM API Keys ---
# The application will prioritize the key specific to the provider you've chosen in config.yml.

# If using DeepSeek directly (model: "deepseek/deepseek-chat")
DEEPSEEK_API_KEY="sk-..."

# If using Gemini (model: "gemini/gemini-flash-latest")
GEMINI_API_KEY="your-gemini-api-key"

# If using OpenRouter as a proxy (works for many models)
OPENROUTER_API_KEY="sk-or-..."

# (Optional) Other providers
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."
