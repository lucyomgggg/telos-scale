# Telos-Scale Environment Variables Template
# Copy this file to .env and fill in your values.

# LLM API Key (Required)
# If using OpenRouter:
OPENROUTER_API_KEY="sk-or-your-api-key-here"

# (Optional) If you are using a different provider, set their keys here.
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."
